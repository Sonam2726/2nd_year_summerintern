   "source": [
    "import numpy as np\n",
    "a=np.array([[6,-8,73,-110],[np.nan,-8,0,94]])\n",
    "print(a)\n",
    "# replacing nan with 0\n",
    "a=np.nan_to_num(a,nan=0)\n",
    "# interchanging row and columns\n",
    "a=a.T\n",
    "print(a)"
   ]
  }
